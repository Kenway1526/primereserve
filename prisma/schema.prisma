generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Restaurante {
  id            String        @id @default(uuid())
  nombre        String
  slug          String        @unique
  direccion     String?
  configuracion Json?
  fechaCreacion DateTime      @default(now())
  ingredientes  Ingrediente[]
  menuItems     MenuItem[]
  mesas         Mesa[]
  reservaciones Reservacion[]
  usuarios      Usuario[]
}

model Usuario {
  id            String        @id @default(uuid())
  email         String        @unique
  password      String
  nombre        String
  telefono      String?
  rol           RolUsuario    @default(CLIENTE)
  restauranteId String?
  fechaCreacion DateTime      @default(now())
  ordenes       Orden[]
  reservaciones Reservacion[]
  restaurante   Restaurante?  @relation(fields: [restauranteId], references: [id])
}

model Reservacion {
  id               String        @id @default(uuid())
  folio            String        @unique
  fechaPrincipal   DateTime
  horaPrincipal    String
  fechaPlanB       DateTime
  horaPlanB        String
  numPersonas      Int           @default(2)
  ocasion          String?
  notasEspeciales  String?
  estado           EstadoReserva @default(WAITLIST)
  isWaitlistActive Boolean       @default(false)
  posicionEspera   Int?
  usuarioId        String
  restauranteId    String
  mesaId           String?
  fechaRegistro    DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  ordenes          Orden[]
  mesa             Mesa?         @relation(fields: [mesaId], references: [id])
  restaurante      Restaurante   @relation(fields: [restauranteId], references: [id])
  usuario          Usuario       @relation(fields: [usuarioId], references: [id])
}

model Mesa {
  id            String        @id @default(uuid())
  numeroMesa    BigInt
  capacidad     Int
  zona          ZonaMesa      @default(PLANTA_BAJA)
  estado        EstadoMesa    @default(LIBRE)
  restauranteId String
  restaurante   Restaurante   @relation(fields: [restauranteId], references: [id])
  ordenes       Orden[]
  reservaciones Reservacion[]

  @@unique([restauranteId, numeroMesa])
}

model MenuItem {
  id             String         @id @default(uuid())
  nombre         String
  descripcion    String?
  precio         Float
  categoria      CategoriaMenu
  estaDisponible Boolean        @default(true)
  imagenUrl      String?
  restauranteId  String
  detallesOrden  DetalleOrden[]
  restaurante    Restaurante    @relation(fields: [restauranteId], references: [id])
  recetas        Receta[]
}

model Orden {
  id            String         @id @default(uuid())
  estado        EstadoOrden    @default(ABIERTA)
  total         Float          @default(0.0)
  mesaId        String
  usuarioId     String
  reservacionId String?
  fechaApertura DateTime       @default(now())
  fechaCierre   DateTime?
  detalles      DetalleOrden[]
  mesa          Mesa           @relation(fields: [mesaId], references: [id])
  reservacion   Reservacion?   @relation(fields: [reservacionId], references: [id])
  usuario       Usuario        @relation(fields: [usuarioId], references: [id])
}

model DetalleOrden {
  id              String     @id @default(uuid())
  cantidad        Int
  precioHistorico Float
  subtotal        Float
  notasCocina     String?
  estadoItem      EstadoItem @default(PENDIENTE)
  ordenId         String
  menuItemId      String
  menuItem        MenuItem   @relation(fields: [menuItemId], references: [id])
  orden           Orden      @relation(fields: [ordenId], references: [id])
}

model Ingrediente {
  id                String      @id @default(uuid())
  nombre            String
  stockActual       Float
  unidad            String
  stockMinimoAlerta Float
  restauranteId     String
  restaurante       Restaurante @relation(fields: [restauranteId], references: [id])
  recetas           Receta[]
}

model Receta {
  menuItemId    String
  ingredienteId String
  cantidadUsada Float
  ingrediente   Ingrediente @relation(fields: [ingredienteId], references: [id])
  menuItem      MenuItem    @relation(fields: [menuItemId], references: [id])

  @@id([menuItemId, ingredienteId])
}

enum RolUsuario {
  ADMIN
  CLIENTE
  MESERO
  COCINA
}

enum EstadoReserva {
  WAITLIST
  CONFIRMADA
  SENTADO
  CANCELADA
  COMPLETADA
}

enum ZonaMesa {
  TERRAZA
  PLANTA_BAJA
}

enum EstadoMesa {
  LIBRE
  OCUPADA
  SUCIA
  RESERVADA
}

enum CategoriaMenu {
  ENTRADAS
  PLATOS_FUERTES
  BEBIDAS
  POSTRES
}

enum EstadoOrden {
  ABIERTA
  EN_PREPARACION
  LISTO
  SERVIDO
  PAGADO
}

enum EstadoItem {
  PENDIENTE
  COCINANDO
  LISTO
  ENTREGADO
}
